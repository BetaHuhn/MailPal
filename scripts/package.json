{
    "name": "mailpal-setup",
    "scripts": {
        "build": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:macos-x64 && bun run build:macos-arm64 && bun run build:windows",
        "build:linux-x64": "bun build --compile --minify --target=bun-linux-x64 ./setup.ts --outfile ./dist/mailpal-setup-linux-x64",
        "build:linux-arm64": "bun build --compile --minify --target=bun-linux-arm64 ./setup.ts --outfile ./dist/mailpal-setup-linux-arm64",
        "build:macos-x64": "bun build --compile --minify --target=bun-darwin-x64 ./setup.ts --outfile ./dist/mailpal-setup-macos-x64",
        "build:macos-arm64": "bun build --compile --minify --target=bun-darwin-arm64 ./setup.ts --outfile ./dist/mailpal-setup-macos-arm64",
        "build:windows": "bun build --compile --minify --target=bun-windows-x64 ./setup.ts --outfile ./dist/mailpal-setup-windows-x64.exe"
    }
}